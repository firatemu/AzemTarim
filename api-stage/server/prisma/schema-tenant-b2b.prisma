// Prisma schema for B2B tenant-specific models
// This schema is used for isolated tenant schemas (e.g., b2b_tenant_123)
// Each tenant gets their own schema with these tables
//
// Usage:
// 1. When provisioning a new tenant, create a new schema
// 2. Run prisma migrate deploy --schema=prisma/schema-tenant-b2b.prisma
//    with DATABASE_URL modified to include ?schema=tenant_schema_name
//
// Differences from main schema:
// - No tenantId field (each schema is isolated to one tenant)
// - No tenant relation (no Tenant table in tenant schemas)
// - Table names remain the same for consistency

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// PRODUCTS & STOCK
// ========================================

model B2BProduct {
  id                 String    @id @default(cuid())
  erpProductId       String
  stockCode          String
  name               String
  description        String?
  brand              String?
  category           String?
  oemCode            String?
  supplierCode       String?
  unit               String?
  erpListPrice       Decimal   @db.Decimal(12, 2)
  erpCreatedAt       DateTime?
  erpUpdatedAt       DateTime?
  isVisibleInB2B     Boolean   @default(true)
  minOrderQuantity   Int       @default(1)
  imageUrl           String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  stocks             B2BStock[]
  cartItems          B2BCartItem[]
  orderItems         B2BOrderItem[]

  @@unique([erpProductId])
  @@unique([stockCode])
  @@index([isVisibleInB2B])
  @@map("b2b_products")
}

model B2BStock {
  id            String     @id @default(cuid())
  productId     String
  warehouseId   String
  warehouseName String
  isAvailable   Boolean    @default(true)
  displayOrder  Int        @default(0)
  updatedAt     DateTime   @updatedAt
  product       B2BProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@map("b2b_stocks")
}

// ========================================
// CUSTOMERS
// ========================================

model B2BCustomer {
  id               String                     @id @default(cuid())
  erpAccountId     String
  name             String
  email            String
  passwordHash     String
  isActive         Boolean                    @default(true)
  customerClassId  String?
  vatDays          Int                        @default(30)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  lastLoginAt      DateTime?
  customerClass    B2BCustomerClass?          @relation(fields: [customerClassId], references: [id], onDelete: SetNull)
  salespersonLinks B2BSalespersonCustomer[]
  carts            B2BCart[]
  orders           B2BOrder[]
  notifications    B2BNotification[]
  accountMovements B2BAccountMovement[]

  @@unique([email])
  @@unique([erpAccountId])
  @@index([isActive])
  @@map("b2b_customers")
}

model B2BCustomerClass {
  id           String        @id @default(cuid())
  name         String
  discountRate Decimal       @default(0) @db.Decimal(5, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  customers    B2BCustomer[]

  @@unique([name])
  @@map("b2b_customer_classes")
}

// ========================================
// SALESPERSONS
// ========================================

model B2BSalesperson {
  id                  String                     @id @default(cuid())
  name                String
  email               String
  passwordHash        String
  isActive            Boolean                    @default(true)
  canViewAllCustomers Boolean                    @default(false)
  canViewAllReports   Boolean                    @default(false)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  customerAssignments B2BSalespersonCustomer[]
  orders              B2BOrder[]

  @@unique([email])
  @@index([isActive])
  @@map("b2b_salespersons")
}

model B2BSalespersonCustomer {
  salespersonId String
  customerId    String
  assignedAt    DateTime       @default(now())
  salesperson   B2BSalesperson @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  customer      B2BCustomer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([salespersonId, customerId])
  @@map("b2b_salesperson_customers")
}

// ========================================
// DISCOUNTS
// ========================================

model B2BDiscount {
  id           String          @id @default(cuid())
  name         String
  type         B2BDiscountType
  targetValue  String
  discountRate Decimal         @db.Decimal(5, 2)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([isActive])
  @@map("b2b_discounts")
}

// ========================================
// CART
// ========================================

model B2BCart {
  id         String        @id @default(cuid())
  customerId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  customer   B2BCustomer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      B2BCartItem[]

  @@unique([customerId])
  @@map("b2b_carts")
}

model B2BCartItem {
  id        String     @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  addedAt   DateTime   @default(now())
  cart      B2BCart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   B2BProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("b2b_cart_items")
}

// ========================================
// DELIVERY METHODS
// ========================================

model B2BDeliveryMethod {
  id           String     @id @default(cuid())
  name         String
  isActive     Boolean    @default(true)
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       B2BOrder[]

  @@index([isActive])
  @@map("b2b_delivery_methods")
}

// ========================================
// ORDERS
// ========================================

model B2BOrder {
  id                  String            @id @default(cuid())
  orderNumber         String
  customerId          String
  salespersonId       String?
  placedBy            B2BOrderPlacedBy
  placedByLabel       String?
  status              B2BOrderStatus    @default(PENDING)
  deliveryBranchId    String?
  deliveryBranchName  String?
  deliveryMethodId    String
  note                String?
  totalListPrice      Decimal           @db.Decimal(14, 2)
  totalDiscountAmount Decimal           @db.Decimal(14, 2)
  totalFinalPrice     Decimal           @db.Decimal(14, 2)
  erpOrderId          String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  customer            B2BCustomer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesperson         B2BSalesperson?   @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  deliveryMethod      B2BDeliveryMethod @relation(fields: [deliveryMethodId], references: [id])
  items               B2BOrderItem[]
  notifications       B2BNotification[]

  @@unique([orderNumber])
  @@index([customerId])
  @@index([status])
  @@map("b2b_orders")
}

model B2BOrderItem {
  id                    String     @id @default(cuid())
  orderId               String
  productId             String
  stockCode             String
  productName           String
  quantity              Int
  listPrice             Decimal    @db.Decimal(12, 2)
  customerClassDiscount Decimal    @default(0) @db.Decimal(12, 2)
  campaignDiscount      Decimal    @default(0) @db.Decimal(12, 2)
  finalPrice            Decimal    @db.Decimal(12, 2)
  createdAt             DateTime   @default(now())
  order                 B2BOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product               B2BProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@map("b2b_order_items")
}

// ========================================
// NOTIFICATIONS
// ========================================

model B2BNotification {
  id         String              @id @default(cuid())
  customerId String
  type       B2BNotificationType
  message    String
  isRead     Boolean             @default(false)
  orderId    String?
  createdAt  DateTime            @default(now())
  customer   B2BCustomer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      B2BOrder?           @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@map("b2b_notifications")
}

// ========================================
// ADVERTISEMENTS
// ========================================

model B2BAdvertisement {
  id           String    @id @default(cuid())
  type         B2BAdType
  imageUrl     String
  linkUrl      String?
  displayOrder Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive, displayOrder])
  @@map("b2b_advertisements")
}

// ========================================
// ACCOUNT MOVEMENTS
// ========================================

model B2BAccountMovement {
  id            String          @id @default(cuid())
  erpMovementId String
  customerId    String
  date          DateTime
  type          B2BMovementType
  description   String?
  debit         Decimal         @default(0) @db.Decimal(12, 2)
  credit        Decimal         @default(0) @db.Decimal(12, 2)
  balance       Decimal         @db.Decimal(12, 2)
  erpInvoiceNo  String?
  dueDate       DateTime?
  isPastDue     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  customer      B2BCustomer     @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([erpMovementId])
  @@index([customerId])
  @@index([date])
  @@map("b2b_account_movements")
}

// ========================================
// ENUMS
// ========================================

enum B2BOrderStatus {
  PENDING
  APPROVED
  REJECTED
  EXPORTED_TO_ERP
  CANCELLED
}

enum B2BOrderPlacedBy {
  CUSTOMER
  SALESPERSON
}

enum B2BNotificationType {
  ORDER_RECEIVED
  ORDER_APPROVED
  ORDER_REJECTED
}

enum B2BAdType {
  HOMEPAGE_BANNER
  LOGIN_POPUP
}

enum B2BMovementType {
  INVOICE
  PAYMENT
  RETURN
  OTHER
}

enum B2BDiscountType {
  CUSTOMER_CLASS
  BRAND
  CATEGORY
  PRODUCT_LIST
}
