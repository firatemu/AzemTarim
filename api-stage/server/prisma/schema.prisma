  createdByUser  User?                    @relation("ProcurementOrderCreatedBy", fields: [createdBy], references: [id])
  deletedByUser  User?                    @relation("ProcurementOrderDeletedBy", fields: [deletedBy], references: [id])
  deliveryNote   PurchaseDeliveryNote?    @relation("ProcurementOrderDeliveryNote", fields: [deliveryNoteId], references: [id])
  tenant         Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser  User?                    @relation("ProcurementOrderUpdatedBy", fields: [updatedBy], references: [id])
  items          ProcurementOrderItem[]
  deliveryNotes  PurchaseDeliveryNote[]   @relation("PurchaseDeliveryNoteSourceOrder")
  invoices       Invoice[]                @relation("ProcurementOrderInvoice")
  logs           PurchaseOrderLocalLog[]

  @@index([accountId])
  @@index([date])
  @@index([orderNo])
  @@index([status])
  @@index([tenantId])
  @@map("procurement_orders")
}

model ProcurementOrderItem {
  id                String           @id @default(uuid())
  orderId           String           @map("order_id")
  productId         String           @map("product_id")
  quantity          Int              @map("quantity")
  deliveredQuantity Int              @default(0) @map("delivered_quantity")
  unitPrice         Decimal          @map("unit_price") @db.Decimal(10, 2)
  vatRate           Int              @map("vat_rate")
  vatAmount         Decimal          @map("vat_amount") @db.Decimal(10, 2)
  amount            Decimal          @map("amount") @db.Decimal(10, 2)
  discountRate      Decimal?         @default(0) @map("discount_rate") @db.Decimal(10, 2)
  discountAmount    Decimal?         @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountType      String?          @default("pct") @map("discount_type")
  unit              String?          @map("unit")
  createdAt         DateTime         @default(now())
  order             ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product          @relation("ProcurementOrderItemProduct", fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("purchase_order_local_items")
}

model PurchaseOrderLocalLog {
  id         String           @id @default(uuid())
  orderId    String           @map("order_id")
  userId     String?          @map("user_id")
  actionType LogAction        @map("action_type")
  changes    String?          @map("changes")
  ipAddress  String?          @map("ip_address")
  userAgent  String?          @map("user_agent")
  createdAt  DateTime         @default(now())
  order      ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user       User?            @relation("PurchaseOrderLocalLogUser", fields: [userId], references: [id])
  tenantId   String?

  @@index([orderId])
  @@index([userId])
  @@index([tenantId])
  @@map("purchase_order_local_logs")
}

model PurchaseDeliveryNote {
  id                    String                     @id @default(uuid())
  deliveryNoteNo        String                     @map("delivery_note_no")
  date                  DateTime                   @default(now()) @map("date")
  tenantId              String?                    @map("tenantId")
  accountId             String                     @map("account_id")
  warehouseId           String?                    @map("warehouse_id")
  sourceType            DeliveryNoteSourceType     @map("source_type")
  sourceId              String?                    @map("source_id")
  status                DeliveryNoteStatus         @default(NOT_INVOICED) @map("status")
  subtotal              Decimal                    @map("total_amount") @db.Decimal(12, 2)
  vatAmount             Decimal                    @map("vat_amount") @db.Decimal(12, 2)
  grandTotal            Decimal                    @map("grand_total") @db.Decimal(12, 2)
  discount              Decimal                    @default(0) @map("discount") @db.Decimal(10, 2)
  notes                 String?                    @map("notes")
  createdBy             String?                    @map("created_by")
  updatedBy             String?                    @map("updated_by")
  deletedBy             String?                    @map("deleted_by")
  deletedAt             DateTime?                  @map("deleted_at")
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  invoice               Invoice?                   @relation("PurchaseDeliveryNoteInvoice")
  account               Account                    @relation("PurchaseDeliveryNoteAccount", fields: [accountId], references: [id])
  createdByUser         User?                      @relation("PurchaseDeliveryNoteCreatedBy", fields: [createdBy], references: [id])
  deletedByUser         User?                      @relation("PurchaseDeliveryNoteDeletedBy", fields: [deletedBy], references: [id])
  warehouse             Warehouse?                 @relation("PurchaseDeliveryNoteWarehouse", fields: [warehouseId], references: [id])
  sourceOrder           ProcurementOrder?          @relation("PurchaseDeliveryNoteSourceOrder", fields: [sourceId], references: [id])
  tenant                Tenant?                    @relation("PurchaseDeliveryNoteTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser         User?                      @relation("PurchaseDeliveryNoteUpdatedBy", fields: [updatedBy], references: [id])
  items                 PurchaseDeliveryNoteItem[]
  logs                  PurchaseDeliveryNoteLog[]
  orderFromDeliveryNote ProcurementOrder?          @relation("ProcurementOrderDeliveryNote")

  @@unique([deliveryNoteNo, tenantId])
  @@index([tenantId])
  @@index([date])
  @@index([accountId])
  @@index([status])
  @@map("purchase_delivery_notes")
}

model PurchaseDeliveryNoteItem {
  id             String               @id @default(uuid())
  tenantId       String?              @map("tenantId")
  deliveryNoteId String               @map("delivery_note_id")
  productId      String               @map("product_id")
  quantity       Int                  @map("quantity")
  unitPrice      Decimal              @map("unit_price") @db.Decimal(10, 2)
  vatRate        Int                  @map("vat_rate")
  vatAmount      Decimal              @map("vat_amount") @db.Decimal(10, 2)
  totalAmount    Decimal              @map("total_amount") @db.Decimal(12, 2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deliveryNote   PurchaseDeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product        Product              @relation("PurchaseDeliveryNoteItemProduct", fields: [productId], references: [id])

  @@index([deliveryNoteId])
  @@index([productId])
  @@index([tenantId])
  @@map("purchase_delivery_note_items")
}

model PurchaseDeliveryNoteLog {
  id             String               @id @default(uuid())
  tenantId       String?              @map("tenantId")
  deliveryNoteId String               @map("delivery_note_id")
  userId         String?              @map("user_id")
  actionType     LogAction            @map("action_type")
  changes        String?              @map("changes")
  ipAddress      String?              @map("ip_address")
  userAgent      String?              @map("user_agent")
  createdAt      DateTime             @default(now())
  deliveryNote   PurchaseDeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  user           User?                @relation("PurchaseDeliveryNoteLogUser", fields: [userId], references: [id])

  @@index([deliveryNoteId])
  @@index([userId])
  @@index([tenantId])
  @@map("purchase_delivery_note_logs")
}

model Module {
  id           String          @id @default(cuid())
  name         String
  slug         String          @unique
  description  String?
  price        Decimal         @db.Decimal(10, 2)
  currency     String          @default("TRY")
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  licenses     ModuleLicense[]
  userLicenses UserLicense[]

  @@index([slug])
  @@index([isActive])
  @@map("modules")
}

model ModuleLicense {
  id             String       @id @default(cuid())
  subscriptionId String
  moduleId       String
  quantity       Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  module         Module       @relation(fields: [moduleId], references: [id])
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([moduleId])
  @@map("module_licenses")
}

model UserLicense {
  id          String      @id @default(cuid())
  userId      String
  licenseType LicenseType
  moduleId    String?
  assignedBy  String?
  assignedAt  DateTime    @default(now())
  revokedAt   DateTime?
  revokedBy   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  module      Module?     @relation(fields: [moduleId], references: [id])
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, licenseType, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([licenseType])
  @@map("user_licenses")
}

model Invitation {
  id         String           @id @default(cuid())
  email      String
  tenantId   String
  invitedBy  String
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  acceptedAt DateTime?
  acceptedBy String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@index([token])
  @@index([status])
  @@map("invitations")
}

model HizliToken {
  id          Int      @id @default(autoincrement())
  token       String
  loginHash   String
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@index([loginHash])
  @@map("hizli_tokens")
}

model EInvoiceInbox {
  id               Int       @id @default(autoincrement())
  ettn             String    @unique
  senderVkn        String
  senderTitle      String
  invoiceNo        String?
  invoiceDate      DateTime?
  rawXml           String?
  createdAt        DateTime  @default(now())
  tenantId         String?   @map("tenant_id")
  matchedInvoiceId String?   @map("matched_invoice_id")
  scenario         String?   @map("scenario") @db.VarChar(50)
  receiverVkn      String?   @map("receiver_vkn") @db.VarChar(11)
  status           String    @default("UNPROCESSED") @db.VarChar(20)
  processedAt      DateTime? @map("processed_at")
  processedById    String?   @map("processed_by")
  tenant           Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  matchedInvoice   Invoice?  @relation("EInvoiceInboxMatchedInvoice", fields: [matchedInvoiceId], references: [id], onDelete: SetNull)
  processedBy      User?     @relation("EInvoiceInboxProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([senderVkn])
  @@index([createdAt])
  @@index([tenantId])
  @@index([matchedInvoiceId])
  @@index([status])
  @@map("einvoice_inbox")
}

