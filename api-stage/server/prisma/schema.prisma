generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  INDIVIDUAL
  CORPORATE
}

model Tenant {
  id                            String                        @id @default(cuid())
  uuid                          String                        @unique @default(uuid())
  name                          String
  subdomain                     String?                       @unique
  domain                        String?                       @unique
  status                        TenantStatus                  @default(TRIAL)
  cancelledAt                   DateTime?
  purgedAt                      DateTime?
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  auditLogs                     AuditLog[]
  bankTransfers                 BankTransfer[]
  unitSets                      UnitSet[]
  simpleOrders                  SimpleOrder[]
  accounts                      Account[]
  checksBills                   CheckBill[]
  invoices                      Invoice[]
  priceLists                    PriceList[]                   @relation("TenantPriceList")
  invitations                   Invitation[]
  invoiceProfits                InvoiceProfit[]
  cashboxes                     Cashbox[]
  expenses                      Expense[]
  employees                     Employee[]
  purchaseOrders                PurchaseOrder[]
  purchaseDeliveryNotes         PurchaseDeliveryNote[]        @relation("PurchaseDeliveryNoteTenant")
  procurementOrders             ProcurementOrder[]
  salesDeliveryNotes            SalesDeliveryNote[]           @relation("SalesDeliveryNoteTenant")
  stocktakes                    Stocktake[]
  salesOrders                   SalesOrder[]
  products                      Product[]
  subscription                  Subscription?
  systemParameters              SystemParameter[]
  collections                   Collection[]
  quotes                        Quote[]
  settings                      TenantSettings?
  users                         User[]
  warehouseTransfers            WarehouseTransfer[]
  warehouses                    Warehouse[]
  banks                         Bank[]
  checkBillJournals             CheckBillJournal[]
  salesAgents                   SalesAgent[]
  salaryPlans                   SalaryPlan[]
  salaryPayments                SalaryPayment[]
  salaryPaymentDetails          SalaryPaymentDetail[]
  advances                      Advance[]
  advanceSettlements            AdvanceSettlement[]
  accountMovements              AccountMovement[]
  productMovements              ProductMovement[]
  invoiceCollections            InvoiceCollection[]
  roles                         Role[]
  expenseCategories             ExpenseCategory[]
  equivalencyGroups             EquivalencyGroup[]
  einvoiceInboxes               EInvoiceInbox[]
  brands                        Brand[]
  categories                    Category[]
  tenantPurgeAudits             TenantPurgeAudit[]
  codeTemplates                 CodeTemplate[]
  tenantType                    TenantType                    @default(CORPORATE)
  companyVehicles               CompanyVehicle[]              @relation("TenantCompanyVehicle")
  vehicleExpenses               VehicleExpense[]              @relation("TenantVehicleExpense")
  posPayments                   PosPayment[]
  posSessions                   PosSession[]

  // Faz 5-8 Relations
  usageMetrics            TenantUsageMetric[]
  featureFlags            FeatureFlag[]
  apiKeys                 ApiKey[]
  webhookEndpoints        WebhookEndpoint[]
  couponRedemptions       CouponRedemption[]
  onboarding              TenantOnboarding?
  einvoiceConfig          EInvoiceTenantConfig?
  einvoiceSends           EInvoiceSend[]
  departments             Department[]
  leaveTypes              LeaveType[]
  leaveRequests           LeaveRequest[]
  overtimeRecords         OvertimeRecord[]
  assetAssignments        AssetAssignment[]
  performanceReviews      PerformanceReview[]
  WarehouseStockThreshold WarehouseStockThreshold[]
  ProductCostingConfig    ProductCostingConfig[]
  ProductLot              ProductLot[]
  priceCards              PriceCard[]
  cashboxMovements        CashboxMovement[]
  bankAccountMovements    BankAccountMovement[]
  bankTransferLogs        BankTransferLog[]
  deletedBankTransfers    DeletedBankTransfer[]
  BankAccount             BankAccount[]
  BankLoan                BankLoan[]
  checkBillEndorsements   CheckBillEndorsement[]
  checkBillCollections    CheckBillCollection[]
  accountTransactions     AccountTransaction[]
  BankLoanPlan            BankLoanPlan[]
  checkBillGlEntries              CheckBillGlEntry[]
  checkBillRiskLimits             CheckBillRiskLimit[]
  checkBillReminders              CheckBillReminder[]
  checkBillProtestTrackings       CheckBillProtestTracking[]
  checkBillBankSubmissions        CheckBillBankSubmission[]
  checkBillDiscountings           CheckBillDiscounting[]
  checkBillReconciliations        CheckBillReconciliation[]
  checkBillApprovalWorkflows      CheckBillApprovalWorkflow[]
  stockMoves                      StockMove[]

  @@index([subdomain])
  @@index([domain])
  @@index([status])
  @@index([createdAt])
  @@map("tenants")
}

model TenantSettings {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  companyName  String?
  taxNumber    String?
  address      String?
  logoUrl      String?
  features     Json?
  limits       Json?
  timezone     String   @default("Europe/Istanbul")
  locale       String   @default("tr-TR")
  currency     String   @default("TRY")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  city         String?
  companyType  String?  @default("COMPANY")
  country      String?
  district     String?
  email        String?
  firstName    String?
  lastName     String?
  mersisNo     String?
  neighborhood String?
  phone        String?
  postalCode   String?
  taxOffice    String?
  tcNo         String?
  website      String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Plan {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("TRY")
  billingPeriod BillingPeriod  @default(MONTHLY)
  trialDays     Int            @default(0)
  baseUserLimit Int            @default(1)
  features      Json?
  limits        Json?
  isActive      Boolean        @default(true)
  isPopular     Boolean        @default(false)
  isBasePlan    Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive])
  @@index([isBasePlan])
  @@map("plans")
}

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  planId                String
  status                SubscriptionStatus @default(TRIAL)
  startDate             DateTime           @default(now())
  endDate               DateTime
  trialEndsAt           DateTime?
  canceledAt            DateTime?
  nextBillingDate       DateTime?
  lastBillingDate       DateTime?
  autoRenew             Boolean            @default(true)
  iyzicoSubscriptionRef String?            @unique
  additionalUsers       Int                @default(0)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  moduleLicenses        ModuleLicense[]
  payments              Payment[]
  plan                  Plan               @relation(fields: [planId], references: [id])
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([endDate])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model ReconciliationLog {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  invoiceId       String?  @map("invoice_id")
  accountId       String?  @map("account_id")
  productId       String?  @map("product_id")
  checkType       String   @map("check_type") // INVOICE | ACCOUNT | PRODUCT | FULL
  isConsistent    Boolean  @map("is_consistent")
  discrepancyData Json?    @map("discrepancy_data")
  checkedAt       DateTime @default(now()) @map("checked_at")
  checkedBy       String?  @map("checked_by")

  @@index([tenantId])
  @@index([invoiceId])
  @@map("reconciliation_logs")
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("TRY")
  status          PaymentStatus @default(PENDING)
  iyzicoPaymentId String?       @unique
  iyzicoToken     String?       @unique
  conversationId  String?       @unique
  invoiceNumber   String?
  invoiceUrl      String?
  paidAt          DateTime?
  failedAt        DateTime?
  refundedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  paymentMethod   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId        String?

  @@index([subscriptionId])
  @@index([status])
  @@index([iyzicoPaymentId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  tenantId   String
  action     String
  resource   String?
  resourceId String?
  meta       Json?    @map("metadata")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id                           String                    @id @default(uuid())
  uuid                         String                    @unique @default(uuid())
  email                        String
  username                     String
  password                     String
  firstName                    String?
  lastName                     String?
  fullName                     String
  phone                        String?
  avatarUrl                    String?
  role                         UserRole                  @default(USER)
  department                   String?
  status                       UserStatus                @default(ACTIVE)
  isActive                     Boolean                   @default(true)
  refreshToken                 String?
  tokenVersion                 Int                       @default(0)
  tenantId                     String?
  emailVerified                Boolean                   @default(false)
  lastLoginAt                  DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt
  bankTransferLogs             BankTransferLog[]
  createdBankTransfers         BankTransfer[]            @relation("BankTransferCreatedBy")
  deletedBankTransfers         BankTransfer[]            @relation("BankTransferDeletedBy")
  updatedBankTransfers         BankTransfer[]            @relation("BankTransferUpdatedBy")
  checkBillLogs                CheckBillLog[]
  createdChecksBills           CheckBill[]               @relation("CheckBillCreatedBy")
  deletedChecksBills           CheckBill[]               @relation("CheckBillDeletedBy")
  updatedChecksBills           CheckBill[]               @relation("CheckBillUpdatedBy")
  deletedBankTransferRecords   DeletedBankTransfer[]     @relation("DeletedBankTransferDeletedBy")
  deletedCheckBillRecords      DeletedCheckBill[]        @relation("DeletedCheckBillDeletedBy")
  invoiceLogs                  InvoiceLog[]
  createdInvoices              Invoice[]                 @relation("InvoiceCreatedBy")
  deletedInvoices              Invoice[]                 @relation("InvoiceDeletedBy")
  updatedInvoices              Invoice[]                 @relation("InvoiceUpdatedBy")
  createdCashboxMovements      CashboxMovement[]         @relation("CashboxMovementCreatedBy")
  createdCashboxes             Cashbox[]                 @relation("CashboxCreatedBy")
  updatedCashboxes             Cashbox[]                 @relation("CashboxUpdatedBy")
  deletedCashboxes             Cashbox[]                 @relation("CashboxDeletedBy")
  createdEmployeePayments      EmployeePayment[]         @relation("EmployeePaymentCreatedBy")
  createdEmployees             Employee[]                @relation("EmployeeCreatedBy")
  updatedEmployees             Employee[]                @relation("EmployeeUpdatedBy")
  createdPriceCards            PriceCard[]               @relation("PriceCardCreatedBy")
  updatedPriceCards            PriceCard[]               @relation("PriceCardUpdatedBy")
  createdPurchaseDeliveryNotes PurchaseDeliveryNote[]    @relation("PurchaseDeliveryNoteCreatedBy")
  deletedPurchaseDeliveryNotes PurchaseDeliveryNote[]    @relation("PurchaseDeliveryNoteDeletedBy")
  updatedPurchaseDeliveryNotes PurchaseDeliveryNote[]    @relation("PurchaseDeliveryNoteUpdatedBy")
  purchaseDeliveryNoteLogs     PurchaseDeliveryNoteLog[] @relation("PurchaseDeliveryNoteLogUser")
  purchaseOrderLocalLogs       PurchaseOrderLocalLog[]   @relation("PurchaseOrderLocalLogUser")
  createdProcurementOrders     ProcurementOrder[]        @relation("ProcurementOrderCreatedBy")
  deletedProcurementOrders     ProcurementOrder[]        @relation("ProcurementOrderDeletedBy")
  updatedProcurementOrders     ProcurementOrder[]        @relation("ProcurementOrderUpdatedBy")
  createdSalesDeliveryNotes    SalesDeliveryNote[]       @relation("SalesDeliveryNoteCreatedBy")
  deletedSalesDeliveryNotes    SalesDeliveryNote[]       @relation("SalesDeliveryNoteDeletedBy")
  updatedSalesDeliveryNotes    SalesDeliveryNote[]       @relation("SalesDeliveryNoteUpdatedBy")
  salesDeliveryNoteLogs        SalesDeliveryNoteLog[]    @relation("SalesDeliveryNoteLogUser")
  createdStocktakes            Stocktake[]               @relation("StocktakeCreatedBy")
  approvedStocktakes           Stocktake[]               @relation("StocktakeApprovedBy")
  updatedStocktakes            Stocktake[]               @relation("StocktakeUpdatedBy")
  sessions                     Session[]
  orderPickings                OrderPicking[]            @relation("OrderPickingCreatedBy")
  salesOrderLogs               SalesOrderLog[]
  createdSalesOrders           SalesOrder[]              @relation("SalesOrderCreatedBy")
  deletedSalesOrders           SalesOrder[]              @relation("SalesOrderDeletedBy")
  updatedSalesOrders           SalesOrder[]              @relation("SalesOrderUpdatedBy")
  stockMoves                   StockMove[]               @relation("StockMoveCreatedBy")
  createdCollections           Collection[]              @relation("CollectionCreatedBy")
  deletedCollections           Collection[]              @relation("CollectionDeletedBy")
  quoteLogs                    QuoteLog[]                @relation("QuoteLogUser")
  createdQuotes                Quote[]                   @relation("QuoteCreatedBy")
  deletedQuotes                Quote[]                   @relation("QuoteDeletedBy")
  updatedQuotes                Quote[]                   @relation("QuoteUpdatedBy")
  licenses                     UserLicense[]
  tenant                       Tenant?                   @relation(fields: [tenantId], references: [id])
  warehouseTransferLogs        WarehouseTransferLog[]
  createdWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferCreatedBy")
  deletedWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferDeletedBy")
  createdJournals              JournalEntry[]            @relation("JournalEntryCreatedBy")
  preparedWarehouseTransfers   WarehouseTransfer[]       @relation("WarehouseTransferPreparer")
  approvedWarehouseTransfers   WarehouseTransfer[]       @relation("WarehouseTransferApprover")
  receivedWarehouseTransfers   WarehouseTransfer[]       @relation("WarehouseTransferReceiver")
  updatedWarehouseTransfers    WarehouseTransfer[]       @relation("WarehouseTransferUpdatedBy")
  checkBillJournalLogs         CheckBillJournal[]        @relation("CheckBillJournalCreatedBy")
  // Duplicate removed
  createdSalaryPayments        SalaryPayment[]           @relation("SalaryPaymentCreatedBy")
  createdAdvances              Advance[]                 @relation("AdvanceCreatedBy")
  roleId                       String?
  roleRelation                 Role?                     @relation(fields: [roleId], references: [id])

  // Faz 4-8 Relations
  managedWarehouses             Warehouse[]             @relation("WarehouseManager")
  enabledFeatureFlags           FeatureFlag[]           @relation("FeatureFlagEnabledBy")
  revokedApiKeys                ApiKey[]                @relation("ApiKeyRevokedBy")
  createdApiKeys                ApiKey[]                @relation("ApiKeyCreatedBy")
  createdWebhooks               WebhookEndpoint[]       @relation("WebhookCreatedBy")
  createdEInvoices              EInvoiceSend[]          @relation("EInvoiceCreatedBy")
  processedEInvoiceInboxes      EInvoiceInbox[]         @relation("EInvoiceInboxProcessedBy")
  managedDepartments            Department[]            @relation("DepartmentManager")
  approvedLeaves                LeaveRequest[]          @relation("LeaveApprovedBy")
  rejectedLeaves                LeaveRequest[]          @relation("LeaveRejectedBy")
  createdLeaves                 LeaveRequest[]          @relation("LeaveCreatedBy")
  approvedOvertimes             OvertimeRecord[]        @relation("OvertimeApprovedBy")
  createdOvertimes              OvertimeRecord[]        @relation("OvertimeCreatedBy")
  assignedAssets                AssetAssignment[]       @relation("AssetAssignedBy")
  returnedAssets                AssetAssignment[]       @relation("AssetReturnedBy")
  performanceReviews            PerformanceReview[]     @relation("PerformanceReviewer")

  // Faz 10 Relations
  deletedAccounts             Account[]             @relation("AccountDeletedBy")
  deletedSalaryPayments       SalaryPayment[]       @relation("SalaryPaymentDeletedBy")
  deletedAccountMovements     AccountMovement[]     @relation("AccountMovementDeletedBy")
  deletedProductMovements     ProductMovement[]     @relation("ProductMovementDeletedBy")
  deletedBankAccountMovements BankAccountMovement[] @relation("BankAccountMovementDeletedBy")
  banksDeleted                Bank[]                @relation("BankDeletedBy")
  performedCheckBillLogs      CheckBillLog[]        @relation("CheckBillLogPerformedBy")
  createdCheckBillCollections CheckBillCollection[] @relation("CheckBillCollectionCreatedBy")
  approvedChecksBills         CheckBill[]               @relation("CheckBillApprovedBy")
  approvedCheckBillJournals   CheckBillJournal[]      @relation("CheckBillJournalApprovedBy")
  postedCheckBillGlEntries    CheckBillGlEntry[]      @relation("CheckBillGlEntryPostedBy")
  approvedCheckBillRiskLimits CheckBillRiskLimit[]    @relation("CheckBillRiskLimitApprovedBy")
  lawyerCheckBillProtests     CheckBillProtestTracking[] @relation("CheckBillProtestLawyer")
  createdCheckBillBankSubmissions CheckBillBankSubmission[] @relation("CheckBillBankSubmissionCreatedBy")
  resolvedCheckBillReconciliations CheckBillReconciliation[] @relation("CheckBillReconciliationResolvedBy")
  approverCheckBillApprovalWorkflows CheckBillApprovalWorkflow[] @relation("CheckBillApprovalApprover")
  delegatedCheckBillApprovalWorkflows CheckBillApprovalWorkflow[] @relation("CheckBillApprovalDelegated")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

model Product {
  id                        String                        @id @default(uuid())
  code                      String                        @map("code")
  tenantId                  String
  name                      String                        @map("name")
  description               String?                       @map("description")
  unit                      String                        @map("unit_text")
  criticalQty               Int                           @default(0) @map("critical_qty")
  category                  String?                       @map("category_text")
  mainCategory              String?                       @map("main_category")
  subCategory               String?                       @map("sub_category")
  brand                     String?                       @map("brand_text")
  model                     String?                       @map("model")
  oem                       String?                       @map("oem")
  shelf                     String?                       @map("shelf")
  barcode                   String?                       @map("barcode")
  supplierCode              String?                       @map("supplier_code")
  equivalencyGroupId        String?                       @map("equivalency_group_id")
  isCategoryOnly            Boolean?                      @default(false) @map("is_category_only")
  isBrandOnly               Boolean?                      @default(false) @map("is_brand_only")
  weight                    Decimal?                      @map("weight") @db.Decimal(12, 4)
  weightUnit                String?                       @map("weight_unit")
  dimensions                String?                       @map("dimensions")
  countryOfOrigin           String?                       @map("country_of_origin")
  warrantyMonths            Int?                          @map("warranty_months")
  internalNote              String?                       @map("internal_note")
  minOrderQty               Int?                          @map("min_order_qty")
  leadTimeDays              Int?                          @map("lead_time_days")
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  simpleOrders              SimpleOrder[]                 @relation("SimpleOrderProduct")
  invoiceItems              InvoiceItem[]
  invoiceProfits            InvoiceProfit[]
  priceCards                PriceCard[]
  productBarcodes           ProductBarcode[]
  productLocationStocks     ProductLocationStock[]
  purchaseOrderItems        PurchaseOrderItem[]           @relation("PurchaseOrderItemProduct")
  purchaseDeliveryNoteItems PurchaseDeliveryNoteItem[]    @relation("PurchaseDeliveryNoteItemProduct")
  procurementOrderItems     ProcurementOrderItem[]        @relation("ProcurementOrderItemProduct")
  productCostHistories      ProductCostHistory[]          @relation("ProductCostHistory")
  priceListItems            PriceListItem[]               @relation("ProductPriceListItem")
  salesDeliveryNoteItems    SalesDeliveryNoteItem[]       @relation("SalesDeliveryNoteItemProduct")
  stocktakeItems            StocktakeItem[]
  salesOrderItems           SalesOrderItem[]              @relation("SalesOrderItemProduct")
  stockMoves                StockMove[]
  equivalents               ProductEquivalent[]           @relation("Product1")
  equivalents2              ProductEquivalent[]           @relation("Product2")
  productMovements          ProductMovement[]
  equivalencyGroup          EquivalencyGroup?             @relation(fields: [equivalencyGroupId], references: [id])
  tenant                    Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteItems                QuoteItem[]
  shelves                   ProductShelf[]
  warehouseCriticalStocks   WarehouseCriticalStock[]
  warehouseTransferItems    WarehouseTransferItem[]
  inventoryTransactions     InventoryTransaction[]
  unitId                    String?                       @map("unit_id")
  unitRef                   Unit?                         @relation(fields: [unitId], references: [id])
  vatRate                   Int                           @default(20) @map("vat_rate")
  // Faz 3 — Normalize edilmiş FK'lar (deprecated String alanlar korunuyor)
  brandId                   String?                       @map("brand_id") // @deprecated brand String? kullan
  categoryId                String?                       @map("category_id") // @deprecated category/mainCategory/subCategory String? kullan
  brandRef                  Brand?                        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryRef               Category?                     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  WarehouseStockThreshold   WarehouseStockThreshold[]
  ProductCostingConfig      ProductCostingConfig?
  ProductLot                ProductLot[]

  @@unique([code, tenantId])
  @@unique([barcode, tenantId])
  @@index([tenantId])
  @@index([tenantId, code])
  @@index([tenantId, barcode])
  @@index([brandId])
  @@index([categoryId])
  @@map("products")
}

// ========== Faz 3 — Normalize Tablolar ==========

model Brand {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  name      String
  slug      String?
  logoUrl   String?   @map("logo_url")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, name])
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("brands")
}

model Category {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  name      String
  slug      String?
  parentId  String?    @map("parent_id")
  level     Int        @default(0)
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryParent")
  products  Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

model PriceCard {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  productId     String        @map("product_id")
  type          PriceCardType
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("TRY")
  isActive      Boolean       @default(true) @map("is_active")
  effectiveFrom DateTime?     @map("effective_from")
  effectiveTo   DateTime?     @map("effective_to")
  vatRate       Decimal       @default(20) @map("vat_rate") @db.Decimal(5, 2)
  minQuantity   Decimal       @default(1) @map("min_quantity") @db.Decimal(12, 2)
  note          String?
  createdBy     String?       @map("created_by")
  updatedBy     String?       @map("updated_by")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  createdByUser User?         @relation("PriceCardCreatedBy", fields: [createdBy], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  updatedByUser User?         @relation("PriceCardUpdatedBy", fields: [updatedBy], references: [id])

  @@index([tenantId])
  @@index([tenantId, updatedAt])
  @@index([productId, type, createdAt])
  @@map("price_cards")
}

model ProductCostHistory {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  cost         Decimal  @db.Decimal(12, 4)
  method       String   @default("WEIGHTED_AVERAGE")
  computedAt   DateTime @default(now()) @map("computed_at")
  brand        String?  @map("brand")
  mainCategory String?  @map("main_category")
  subCategory  String?  @map("sub_category")
  note         String?
  product      Product  @relation("ProductCostHistory", fields: [productId], references: [id], onDelete: Cascade)
  tenantId     String?

  @@index([productId, computedAt])
  @@index([tenantId])
  @@map("stock_cost_history")
}

model EquivalencyGroup {
  id          String    @id @default(uuid())
  tenantId    String
  name        String?   @map("name")
  description String?   @map("description")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("equivalency_groups")
}

model ProductEquivalent {
  id         String   @id @default(uuid())
  product1Id String   @map("product1_id")
  product2Id String   @map("product2_id")
  createdAt  DateTime @default(now())
  product1   Product  @relation("Product1", fields: [product1Id], references: [id], onDelete: Cascade)
  product2   Product  @relation("Product2", fields: [product2Id], references: [id], onDelete: Cascade)
  tenantId   String?

  @@unique([product1Id, product2Id])
  @@index([tenantId])
  @@map("product_equivalents")
}

model ProductMovement {
  id            String       @id @default(uuid())
  productId     String       @map("product_id")
