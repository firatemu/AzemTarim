  name                 String?               @map("name")
  accountNo            String?               @map("account_no")
  iban                 String?               @map("iban")
  type                 BankAccountType       @map("type")
  balance              Decimal               @default(0) @map("balance") @db.Decimal(15, 2)
  isActive             Boolean               @default(true) @map("is_active")
  // POS hesapları için
  commissionRate       Decimal?              @map("commission_rate") @db.Decimal(5, 2)
  // Kredi hesapları için
  creditLimit          Decimal?              @map("credit_limit") @db.Decimal(15, 2)
  usedCreditLimit      Decimal?              @map("used_credit_limit") @db.Decimal(15, 2)
  // Firma kredi kartları için
  cardLimit            Decimal?              @map("card_limit") @db.Decimal(15, 2)
  statementDay         Int?                  @map("statement_day")
  paymentDueDay        Int?                  @map("payment_due_day")
  terminalNo           String?               @map("terminal_no")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  movements            BankAccountMovement[]
  bank                 Bank                  @relation(fields: [bankId], references: [id], onDelete: Cascade)
  collections          Collection[]
  salaryPaymentDetails SalaryPaymentDetail[]
  loans                BankLoan[]
  bankTransfers        BankTransfer[]
  checkBillJournals    CheckBillJournal[]
  tenantId             String?
  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checkBillColRecords       CheckBillCollection[]       @relation("CheckBillCollectionBank")
  checkBillBankSubmissions  CheckBillBankSubmission[]
  checkBillDiscountings     CheckBillDiscounting[]
  checkBillReconciliations  CheckBillReconciliation[]

  @@index([bankId])
  @@index([type])
  @@index([tenantId])
  @@map("bank_accounts")
}

// Banka Hesap Hareketleri - Tüm hesap hareketleri
model BankAccountMovement {
  id               String               @id @default(uuid())
  bankAccountId    String               @map("bank_account_id")
  movementType     BankMovementType     @map("movement_type")
  movementSubType  BankMovementSubType? @map("movement_sub_type")
  amount           Decimal              @map("amount") @db.Decimal(15, 2)
  commissionRate   Decimal?             @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal?             @map("commission_amount") @db.Decimal(15, 2)
  netAmount        Decimal?             @map("net_amount") @db.Decimal(15, 2)
  balance          Decimal              @map("balance") @db.Decimal(15, 2)
  notes            String?              @map("notes")
  referenceNo      String?              @map("reference_no")
  accountId        String?              @map("account_id")
  date             DateTime             @default(now()) @map("date")
  createdAt        DateTime             @default(now())
