  totalInterest      Decimal        @map("total_interest") @db.Decimal(15, 2)
  installmentCount   Int            @map("installment_count")
  startDate          DateTime       @map("start_date")
  notes              String?        @map("notes")
  loanType           LoanType       @default(EQUAL_INSTALLMENT) @map("loan_type")
  status             LoanStatus     @default(ACTIVE) @map("status")
  annualInterestRate Decimal?       @map("annual_interest_rate") @db.Decimal(5, 2)
  paymentFrequency   Int            @default(1) @map("payment_frequency")
  tenantId           String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  bankAccount        BankAccount    @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  plans              BankLoanPlan[]
  tenant             Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([tenantId])
  @@map("bank_loans")
}

model BankLoanPlan {
  id            String           @id @default(uuid())
  loanId        String           @map("loan_id")
  installmentNo Int              @map("installment_no")
  dueDate       DateTime         @map("due_date")
  amount        Decimal          @map("amount") @db.Decimal(15, 2)
  paidAmount    Decimal          @default(0) @map("paid_amount") @db.Decimal(15, 2)
