# Development Dockerfile - HMR aktif
FROM node:20-alpine

WORKDIR /app

# pnpm kur
RUN npm install -g pnpm@10

# Node dependencies kur
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Kaynak kodu kopyala
COPY . .

# Development environment variables
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Port açık
EXPOSE 3000

# HMR için - development server başlat
CMD ["pnpm", "dev"]